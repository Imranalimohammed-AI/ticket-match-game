# Ticket Triage Web Game — Secrets
# Copy this file to web/.env and fill in real values.
# Run web/setup_admin.py once to generate ADMIN_PASSWORD_HASH.
# NEVER commit web/.env to version control.

# Flask session signing key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-hex-string

# Admin password hash — generated by: python web/setup_admin.py
ADMIN_PASSWORD_HASH=
